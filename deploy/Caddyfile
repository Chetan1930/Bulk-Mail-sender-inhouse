# Optional HTTPS — install Caddy on the EC2 host, then:
#   sudo cp deploy/Caddyfile /etc/caddy/Caddyfile
#   sudo systemctl reload caddy
#
# Set APP_PORT=8080 in .env so Docker frontend listens on 8080,
# and Caddy handles public ports 80/443.
#
# Update FRONTEND_URL to https://sendingmail.chetanchauhan.fun

sendingmail.chetanchauhan.fun {
    reverse_proxy localhost:8080
}
