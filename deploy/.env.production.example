# Production env for EC2 — copy to repo root as .env:
#   cp deploy/.env.production.example .env

# Must match the URL users open in the browser (no trailing slash)
FRONTEND_URL=http://sendingmail.chetanchauhan.fun

# Docker frontend port on the host.
# Use 8080 if Ubuntu nginx already uses port 80 (see deploy/nginx-host.conf).
APP_PORT=8080

# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret

# Seed admin on first deploy; set false after logging in once
SEED_ON_START=true
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=

# Email provider (at least one recommended for real sends)
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
