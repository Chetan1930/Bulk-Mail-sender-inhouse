# Production env for EC2 — copy to repo root as .env:
#   cp deploy/.env.production.example .env

# Must match the URL users open in the browser (no trailing slash)
FRONTEND_URL=http://sendingmail.chetanchauhan.fun

# Docker exposes frontend nginx on this host port
APP_PORT=80

# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret

# Demo users on first deploy; set false after logging in once
SEED_ON_START=true

# Email provider (at least one recommended for real sends)
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
