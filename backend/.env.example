DATABASE_URL="postgresql://postgres:postgres@localhost:5434/mailflow"
REDIS_URL="redis://localhost:6380"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
PORT=3001
FRONTEND_URL="http://localhost:5173"

# Keep false — provision users via seed or database only
ALLOW_PUBLIC_SIGNUP=false

# Admin user for npm run prisma:seed (set in .env only — never commit real values)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=

# Email Providers (optional - configure as needed)
SENDGRID_API_KEY=""
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
