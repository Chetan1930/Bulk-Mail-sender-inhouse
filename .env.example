# Copy to .env and update before deploying:
#   cp .env.example .env

# Public URL users open in the browser (no trailing slash)
# Local:  http://localhost
# EC2:    http://sendingmail.chetanchauhan.fun
FRONTEND_URL=http://localhost

# Host port for the web UI (default 80)
APP_PORT=80

# Set a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Login-only: keep false in production (you provision users via SEED_ADMIN_*)
ALLOW_PUBLIC_SIGNUP=false

# Seed admin user on start — set SEED_ADMIN_* in .env only (not in this file)
SEED_ON_START=true
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=

# Optional email provider defaults
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
