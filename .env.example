# Copy to .env and update before deploying:
#   cp .env.example .env

# Public URL users open in the browser (no trailing slash)
FRONTEND_URL=http://localhost

# Host port for the web UI (default 80)
APP_PORT=80

# Set a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Seed demo users on first start (admin@mailflow.com / admin123)
SEED_ON_START=true

# Optional email provider defaults
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
